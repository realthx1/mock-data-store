{
  "file_types": {
    "JSONC": ["luaurc"],
  },
  "lsp": {
    "json-language-server": {
      "settings": {
        "json": {
          "schemas": [
            {
              "fileMatch": [".luaurc"],
              "url": "https://raw.githubusercontent.com/JohnnyMorganz/luau-lsp/refs/heads/main/editors/code/schemas/luaurc.json",
            },
            {
              "fileMatch": ["*.project.json"],
              "url": "https://raw.githubusercontent.com/rojo-rbx/vscode-rojo/refs/heads/master/schemas/project.template.schema.json",
            },
          ],
        },
      },
    },
    "luau-lsp": {
      "settings": {
        "luau-lsp": {
          "ignoreGlobs": ["*_packages/**", ".pesde/**"],
          "sourcemap": {
            "autogenerate": true,
            "rojoProjectFile": "default.project.json",
            "includeNonScripts": true,
            "sourcemapFile": "sourcemap.json",
          },
          "diagnostics": {
            "includeDependents": true,
            "workspace": false,
            "strictDatamodelTypes": true,
          },
          "completion": {
            "ignoreGlobs": ["**/.pesde/**"],
          },
        },
        "roblox": {
          "security_level": "local_user",
        },
      },
    },
  },
  "languages": {
    "Luau": {
      "formatter": {
        "external": {
          "command": "stylua",
          "arguments": ["--verify", "-"],
        },
      },
    },
  },
}
